# ==============================================================================

# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
gollm
gollm.exe
gollm_*

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out
*.cov
coverage.html
coverage.xml
coverage.txt
*_coverage.out

# Dependency directories
vendor/

# Go workspace file
go.work
go.work.sum

# Build directories
bin/
build/
dist/
releases/

