# ==============================================================================
# ✅ FORCE INCLUDE (OVERRIDE IGNORES)
# ==============================================================================

# Force include important example configs (without secrets)
!config.example.yaml
!config.example.yml
!config.example.json
!.env.example

# Force include example provider configs
!examples/config/
!docs/examples/

# Force include CI/CD configuration files (public parts)
!.github/workflows/
!.gitlab-ci.yml
!.circleci/config.yml

