config.yaml
config.yml
config.json
config.toml
.env
.env.local
.env.production
.env.staging
.env.development

# API keys and secrets
*.key
*.pem
*.crt
*.cert
*.p12
*.pfx
api_keys/
secrets/
credentials/

# Session and temporary auth data
.gollm/
.session/
*.session
auth_token*
refresh_token*

# ==============================================================================
